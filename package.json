{
  "name": "oas-generator",
  "description": "OAS Generator",
  "repository": "https://github.com/edoardomistretta/oas-generator",
  "author": "Edoardo Mistretta",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node --trace-warnings -r ./config/ts-node src/index.ts",
    "tc": "ttsc --p ./config/tsconfig.typecheck.json",
    "lint": "eslint",
    "test": "jest --runInBand --config ./config/jest.config.json",
    "pre-commit": "npm run tc && npm run test && npm run lint ./src ./test"
  },
  "devDependencies": {
    "@types/jest": "^29.5.1",
    "@types/node": "^20.1.3",
    "@typescript-eslint/eslint-plugin": "^5.59.5",
    "@typescript-eslint/parser": "^5.59.5",
    "eslint": "^8.40.0",
    "eslint-config-xo": "^0.43.1",
    "eslint-config-xo-typescript": "^0.57.0",
    "fp-ts": "^2.15.0",
    "jest": "^29.5.0",
    "monocle-ts": "^2.3.13",
    "prettier": "^2.8.8",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ttypescript": "^1.5.15",
    "typescript": "^4.9.5",
    "typescript-transform-paths": "^3.4.6"
  }
}
